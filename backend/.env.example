# DemandTest Platform 环境变量配置

# 应用配置
APP_NAME=DemandTest Platform
APP_VERSION=3.0.0
DEBUG=true

# 爬虫配置
CRAWLER_TIMEOUT=60
CRAWLER_HEADLESS=true

# 文件存储
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
DATA_DIR=./data
CONFIG_DIR=./data/config
SESSION_DIR=./data/sessions

# OCR 配置
OCR_API_KEY=your_ocr_api_key
OCR_API_URL=https://api.ocr.space/parse/image

# LLM 配置
# API 类型: glm, gpt, qwen, ernie, custom
LLM_API_TYPE=glm
LLM_MODEL_NAME=glm-4
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# 知识库配置
KB_ENABLED=true
KB_STORAGE_DIR=./data/knowledge
KB_EMBEDDING_PROVIDER=local
KB_EMBEDDING_MODEL=text-embedding-ada-002
KB_CHUNK_SIZE=500

# 学习系统配置
LEARNING_ENABLED=true
LEARNING_STORAGE_DIR=./data/learning

# 会话配置
SESSION_TIMEOUT=3600
SESSION_MAX_HISTORY=50
